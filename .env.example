# ── Required ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ── Auth / Security ───────────────────────────────────────────────────────
VITE_TURNSTILE_SITE_KEY="0x4AAAAAA..."   # Cloudflare Turnstile (login/signup)

# ── Payment ───────────────────────────────────────────────────────────────
VITE_FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-..."

# ── Analytics / Monitoring ────────────────────────────────────────────────
VITE_POSTHOG_API_KEY="phc_..."
VITE_POSTHOG_API_HOST="https://us.i.posthog.com"
VITE_SENTRY_DSN="https://..."

# ── Widget ────────────────────────────────────────────────────────────────
VITE_WIDGET_WHATSAPP="+1234567890"       # Optional: WhatsApp contact link
VITE_WIDGET_EMAIL="support@example.com"  # Optional: Email contact link

# ── Features ──────────────────────────────────────────────────────────────
VITE_ENABLE_VOICE="true"                 # Enable voice input in widget
VITE_APP_URL="https://your-app.com"      # Used by embed SDK origin check

# ── Edge Functions (set in Supabase dashboard → Edge Functions secrets) ───
# SUPABASE_URL                          (injected by Supabase runtime)
# SUPABASE_ANON_KEY                     (injected by Supabase runtime)
# SUPABASE_SERVICE_ROLE_KEY             (service-role key — keep secret)
# SUPABASE_PUBLISHABLE_KEY              (publishable anon key)
# AI_API_KEY                            (OpenRouter or compatible API key)
# AI_BASE_URL="https://openrouter.ai/api"
# AI_MODEL="google/gemini-2.5-flash"
# FLUTTERWAVE_SECRET_KEY                (Flutterwave secret key)
# FLUTTERWAVE_SECRET_HASH               (Flutterwave webhook verification hash)
# RESEND_API_KEY                        (Resend API key for follow-up email delivery)
# LIGHTHOUSE_PAGESPEED_API_KEY          (Google PageSpeed Insights API key for real audits)
# PROCESS_FOLLOW_UPS_SECRET             (Shared secret — internal auth for follow-ups function)
# SEND_WEBHOOK_SECRET                   (Shared secret — internal auth for webhook function)
